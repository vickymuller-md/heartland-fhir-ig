     fhir:linkId [ fhir:v "egfr-low" ] ;
     fhir:text [ fhir:v "eGFR <45 mL/min/1.73m^2" ] ;
     fhir:type [ fhir:v "boolean" ] ;
     fhir:required [ fhir:v true ]
  ] [
     fhir:linkId [ fhir:v "natriuretic-high" ] ;
     fhir:text [ fhir:v "BNP >=500 pg/mL or NT-proBNP >=1500 pg/mL" ] ;
     fhir:type [ fhir:v "boolean" ] ;
     fhir:required [ fhir:v true ]
  ] [
     fhir:linkId [ fhir:v "sbp-low" ] ;
     fhir:text [ fhir:v "Systolic BP <100 mmHg at admission" ] ;
     fhir:type [ fhir:v "boolean" ] ;
     fhir:required [ fhir:v true ]
  ] [
     fhir:linkId [ fhir:v "diabetes" ] ;
     fhir:text [ fhir:v "Diabetes mellitus" ] ;
     fhir:type [ fhir:v "boolean" ] ;
     fhir:required [ fhir:v true ]
  ] [
     fhir:linkId [ fhir:v "lvef-low" ] ;
     fhir:text [ fhir:v "LVEF <30%" ] ;
     fhir:type [ fhir:v "boolean" ] ;
     fhir:required [ fhir:v true ]
  ] [
     fhir:linkId [ fhir:v "ckm-stage" ] ;
     fhir:text [ fhir:v "Cardiovascular-kidney-metabolic (CKM) Stage 3 or 4" ] ;
     fhir:type [ fhir:v "boolean" ] ;
     fhir:required [ fhir:v true ]
  ] [
     fhir:linkId [ fhir:v "distance-far" ] ;
     fhir:text [ fhir:v "Distance to cardiology care >50 miles" ] ;
     fhir:type [ fhir:v "boolean" ] ;
     fhir:required [ fhir:v true ]
  ] [
     fhir:linkId [ fhir:v "social-support" ] ;
     fhir:text [ fhir:v "Lives alone or limited social support" ] ;
     fhir:type [ fhir:v "boolean" ] ;
     fhir:required [ fhir:v true ]
  ] ) . # 

