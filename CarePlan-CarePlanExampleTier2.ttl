  ] [
     fhir:detail [
       fhir:status [ fhir:v "scheduled" ] ;
       fhir:description [ fhir:v "7-day in-person follow-up visit at FQHC for vitals, medication reconciliation, and GDMT titration." ]
     ]
  ] [
     fhir:detail [
       fhir:status [ fhir:v "scheduled" ] ;
       fhir:scheduled [
         a fhir:Timing ;
         fhir:repeat [
