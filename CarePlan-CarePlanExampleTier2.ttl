<https://heartlandprotocol.org/fhir/CarePlan/CarePlanExampleTier2> a fhir:CarePlan ;
  fhir:nodeRole fhir:treeRoot ;
  fhir:id [ fhir:v "CarePlanExampleTier2"] ; # 
  fhir:meta [
     fhir:profile ( [
