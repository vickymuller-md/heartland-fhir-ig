       fhir:name [ fhir:v "Example: High-Risk HEARTLAND Risk Assessment" ] ;
       fhir:description [ fhir:v "Risk assessment for PatientExampleRural scoring 11/18 points (>=9 = High Risk tier). Inputs: age >=75 (+2), prior HF hosp 6mo (+3), eGFR <45 (+2), BP <100 (+2), distance >50 mi (+1), limited social support (+1). Triggers Intensive Bundle per HEARTLAND v3.2." ] ;
