       fhir:name [ fhir:v "Example: Body Weight Observation with Red-Flag Threshold" ] ;
       fhir:description [ fhir:v "Body weight observation for PatientExampleRural captured via Track B (telephone-reported) showing a +1.2 kg gain in 24 hours. Reference range encodes the HEARTLAND default red-flag threshold (>=0.9 kg in 24 hours triggers clinician outreach per the human filter principle)." ] ;
