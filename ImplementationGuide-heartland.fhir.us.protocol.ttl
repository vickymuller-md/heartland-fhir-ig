         fhir:reference [ fhir:v "CarePlan/CarePlanExampleTier2" ]
       ] ;
       fhir:name [ fhir:v "Example: Tier 2 Care Plan with Track B Monitoring" ] ;
       fhir:description [ fhir:v "Care plan for PatientExampleRural at a Tier 2 (Standard) FQHC. Patient was assigned Track B (analog) because rural broadband is unreliable. Plan includes target initiation of all 4 GDMT classes within 14 days, weekly follow-up calls for 4 weeks, 7-day in-person visit, and full 8-domain teach-back education." ] ;
       fhir:example [
         a fhir:Canonical ;
         fhir:v "https://fhir.heartlandprotocol.org/StructureDefinition/heartland-careplan"^^xsd:anyURI ;
