       ] ;
       fhir:name [ fhir:v "HEARTLAND Distance to Cardiology" ] ;
       fhir:description [ fhir:v "Driving distance in miles from the patient's residence to the nearest cardiologist. Used by the HEARTLAND risk score: distance >50 miles contributes 1 point. Rural counties without a cardiologist average 87 miles to nearest cardiology care vs 16 miles in counties with one (HEARTLAND Protocol v3.2, Module 2)." ] ;
