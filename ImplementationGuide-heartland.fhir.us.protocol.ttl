         fhir:reference [ fhir:v "StructureDefinition/heartland-careplan" ]
       ] ;
       fhir:name [ fhir:v "HEARTLAND Care Plan" ] ;
       fhir:description [ fhir:v "Heart failure care plan structured per HEARTLAND Protocol v3.2. Activities are organized around five domains: GDMT initiation/titration, remote monitoring schedule, post-discharge follow-up (calls and visits), discharge education (3 condensed or 8 comprehensive domains), and patient assistance navigation. Two extensions identify the facility implementation tier and the assigned monitoring track (A digital / B analog)." ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
