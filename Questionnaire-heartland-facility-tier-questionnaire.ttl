<https://heartlandprotocol.org/fhir/Questionnaire/heartland-facility-tier-questionnaire> a fhir:Questionnaire ;
  fhir:nodeRole fhir:treeRoot ;
  fhir:id [ fhir:v "heartland-facility-tier-questionnaire"] ; # 
  fhir:text [
     fhir:status [ fhir:v "extensions" ] ;
     fhir:div [ fhir:v "<div xmlns=\"http://www.w3.org/1999/xhtml\"><p class=\"res-header-id\"><b>Narrativa gerada: Questionnaire heartland-facility-tier-questionnaire</b></p><a name=\"heartland-facility-tier-questionnaire\"> </a><a name=\"hcheartland-facility-tier-questionnaire\"> </a><b>Estrutura</b><table border=\"1\" cellpadding=\"0\" cellspacing=\"0\" style=\"border: 1px #F0F0F0 solid; font-size: 11px; font-family: verdana; vertical-align: top;\"><tr style=\"border: 2px #F0F0F0 solid; font-size: 11px; font-family: verdana; vertical-align: top\"><th style=\"vertical-align: top; text-align : var(--ig-left,left); background-color: white; border: 1px #F0F0F0 solid; padding:0px 4px 0px 4px; padding-top: 3px; padding-bottom: 3px\" class=\"hierarchy\"><a href=\"https://hl7.org/fhir/R4/formats.html#table\" title=\"O linkID do item\">ID da ligação</a></th><th style=\"vertical-align: top; text-align : var(--ig-left,left); background-color: white; border: 1px #F0F0F0 solid; padding:0px 4px 0px 4px; padding-top: 3px; padding-bottom: 3px\" class=\"hierarchy\"><a href=\"https://hl7.org/fhir/R4/formats.html#table\" title=\"Texto para o item\">Texto</a></th><th style=\"vertical-align: top; text-align : var(--ig-left,left); background-color: white; border: 1px #F0F0F0 solid; padding:0px 4px 0px 4px; padding-top: 3px; padding-bottom: 3px\" class=\"hierarchy\"><a href=\"https://hl7.org/fhir/R4/formats.html#table\" title=\"Número mínimo e máximo de vezes que o item pode aparecer na instância\">Cardinalidade</a></th><th style=\"vertical-align: top; text-align : var(--ig-left,left); background-color: white; border: 1px #F0F0F0 solid; padding:0px 4px 0px 4px; padding-top: 3px; padding-bottom: 3px\" class=\"hierarchy\"><a href=\"https://hl7.org/fhir/R4/formats.html#table\" title=\"O tipo do item\">Tipo</a></th><th style=\"vertical-align: top; text-align : var(--ig-left,left); background-color: white; border: 1px #F0F0F0 solid; padding:0px 4px 0px 4px; padding-top: 3px; padding-bottom: 3px\" class=\"hierarchy\"><a href=\"https://hl7.org/fhir/R4/formats.html#table\" title=\"Informações adicionais sobre o artigo\">Descrição e condicionalismos</a><span style=\"float: right\"><a href=\"https://hl7.org/fhir/R4/formats.html#table\" title=\"Legend for this format\"><img src=\"data:image/png;base64,\" alt=\"doco\" style=\"background-color: inherit\"/></a></span></th></tr><tr style=\"border: 1px #F0F0F0 solid; padding:0px; vertical-align: top; background-color: white\"><td style=\"vertical-align: top; text-align : var(--ig-left,left); background-color: white; border: 1px #F0F0F0 solid; padding:0px 4px 0px 4px; white-space: nowrap; background-image: url(tbl_bck1.png)\" class=\"hierarchy\"><img src=\"tbl_spacer.png\" alt=\".\" style=\"background-color: inherit\" class=\"hierarchy\"/><img src=\"icon_q_root.gif\" alt=\".\" style=\"background-color: white; background-color: inherit\" title=\"QuestionárioRaiz\" class=\"hierarchy\"/> HeartlandFacilityTierQuestionnaire</td><td style=\"vertical-align: top; text-align : var(--ig-left,left); background-color: white; border: 1px #F0F0F0 solid; padding:0px 4px 0px 4px\" class=\"hierarchy\">Facility self-assessment for HEARTLAND implementation tier (1/2/3). Qualitative scoring; see narrative for tier mapping.</td><td style=\"vertical-align: top; text-align : var(--ig-left,left); background-color: white; border: 1px #F0F0F0 solid; padding:0px 4px 0px 4px\" class=\"hierarchy\"/><td style=\"vertical-align: top; text-align : var(--ig-left,left); background-color: white; border: 1px #F0F0F0 solid; padding:0px 4px 0px 4px\" class=\"hierarchy\">Questionário</td><td style=\"vertical-align: top; text-align : var(--ig-left,left); background-color: white; border: 1px #F0F0F0 solid; padding:0px 4px 0px 4px\" class=\"hierarchy\">https://heartlandprotocol.org/fhir/Questionnaire/heartland-facility-tier-questionnaire#0.1.0</td></tr>#xD;\n<tr style=\"border: 1px #F0F0F0 solid; padding:0px; vertical-align: top; background-color: #F7F7F7\"><td style=\"vertical-align: top; text-align : var(--ig-left,left); background-color: #F7F7F7; border: 1px #F0F0F0 solid; padding:0px 4px 0px 4px; white-space: nowrap; background-image: url(tbl_bck10.png)\" id=\"item.staffing-level\" class=\"hierarchy\"><img src=\"tbl_spacer.png\" alt=\".\" style=\"background-color: inherit\" class=\"hierarchy\"/><img src=\"tbl_vjoin.png\" alt=\".\" style=\"background-color: inherit\" class=\"hierarchy\"/><img src=\"icon-q-coding.png\" alt=\".\" style=\"background-color: #F7F7F7; background-color: inherit\" title=\"coding\" class=\"hierarchy\"/> staffing-level</td><td style=\"vertical-align: top; text-align : var(--ig-left,left); background-color: #F7F7F7; border: 1px #F0F0F0 solid; padding:0px 4px 0px 4px\" class=\"hierarchy\">Which staffing model is available for heart failure care at your facility?</td><td style=\"vertical-align: top; text-align : var(--ig-left,left); background-color: #F7F7F7; border: 1px #F0F0F0 solid; padding:0px 4px 0px 4px\" class=\"hierarchy\">1..1</td><td style=\"vertical-align: top; text-align : var(--ig-left,left); background-color: #F7F7F7; border: 1px #F0F0F0 solid; padding:0px 4px 0px 4px\" class=\"hierarchy\"><a href=\"https://hl7.org/fhir/R4/codesystem-item-type.html#item-type-choice\">choice</a></td><td style=\"vertical-align: top; text-align : var(--ig-left,left); background-color: #F7F7F7; border: 1px #F0F0F0 solid; padding:0px 4px 0px 4px\" class=\"hierarchy\">Opções: <a href=\"#opt-item.staffing-level\">3 options</a></td></tr>#xD;\n<tr style=\"border: 1px #F0F0F0 solid; padding:0px; vertical-align: top; background-color: white\"><td style=\"vertical-align: top; text-align : var(--ig-left,left); background-color: white; border: 1px #F0F0F0 solid; padding:0px 4px 0px 4px; white-space: nowrap; background-image: url(tbl_bck10.png)\" id=\"item.pharmd-available\" class=\"hierarchy\"><img src=\"tbl_spacer.png\" alt=\".\" style=\"background-color: inherit\" class=\"hierarchy\"/><img src=\"tbl_vjoin.png\" alt=\".\" style=\"background-color: inherit\" class=\"hierarchy\"/><img src=\"icon-q-boolean.png\" alt=\".\" style=\"background-color: white; background-color: inherit\" title=\"boolean\" class=\"hierarchy\"/> pharmd-available</td><td style=\"vertical-align: top; text-align : var(--ig-left,left); background-color: white; border: 1px #F0F0F0 solid; padding:0px 4px 0px 4px\" class=\"hierarchy\">Is a PharmD available on-site or by consult to support GDMT titration?</td><td style=\"vertical-align: top; text-align : var(--ig-left,left); background-color: white; border: 1px #F0F0F0 solid; padding:0px 4px 0px 4px\" class=\"hierarchy\">1..1</td><td style=\"vertical-align: top; text-align : var(--ig-left,left); background-color: white; border: 1px #F0F0F0 solid; padding:0px 4px 0px 4px\" class=\"hierarchy\"><a href=\"https://hl7.org/fhir/R4/codesystem-item-type.html#item-type-boolean\">boolean</a></td><td style=\"vertical-align: top; text-align : var(--ig-left,left); background-color: white; border: 1px #F0F0F0 solid; padding:0px 4px 0px 4px\" class=\"hierarchy\"/></tr>#xD;\n<tr style=\"border: 1px #F0F0F0 solid; padding:0px; vertical-align: top; background-color: #F7F7F7\"><td style=\"vertical-align: top; text-align : var(--ig-left,left); background-color: #F7F7F7; border: 1px #F0F0F0 solid; padding:0px 4px 0px 4px; white-space: nowrap; background-image: url(tbl_bck10.png)\" id=\"item.chw-program\" class=\"hierarchy\"><img src=\"tbl_spacer.png\" alt=\".\" style=\"background-color: inherit\" class=\"hierarchy\"/><img src=\"tbl_vjoin.png\" alt=\".\" style=\"background-color: inherit\" class=\"hierarchy\"/><img src=\"icon-q-coding.png\" alt=\".\" style=\"background-color: #F7F7F7; background-color: inherit\" title=\"coding\" class=\"hierarchy\"/> chw-program</td><td style=\"vertical-align: top; text-align : var(--ig-left,left); background-color: #F7F7F7; border: 1px #F0F0F0 solid; padding:0px 4px 0px 4px\" class=\"hierarchy\">What level of community health worker (CHW) program does your facility have?</td><td style=\"vertical-align: top; text-align : var(--ig-left,left); background-color: #F7F7F7; border: 1px #F0F0F0 solid; padding:0px 4px 0px 4px\" class=\"hierarchy\">1..1</td><td style=\"vertical-align: top; text-align : var(--ig-left,left); background-color: #F7F7F7; border: 1px #F0F0F0 solid; padding:0px 4px 0px 4px\" class=\"hierarchy\"><a href=\"https://hl7.org/fhir/R4/codesystem-item-type.html#item-type-choice\">choice</a></td><td style=\"vertical-align: top; text-align : var(--ig-left,left); background-color: #F7F7F7; border: 1px #F0F0F0 solid; padding:0px 4px 0px 4px\" class=\"hierarchy\">Opções: <a href=\"#opt-item.chw-program\">3 options</a></td></tr>#xD;\n<tr style=\"border: 1px #F0F0F0 solid; padding:0px; vertical-align: top; background-color: white\"><td style=\"vertical-align: top; text-align : var(--ig-left,left); background-color: white; border: 1px #F0F0F0 solid; padding:0px 4px 0px 4px; white-space: nowrap; background-image: url(tbl_bck10.png)\" id=\"item.monitoring-tech\" class=\"hierarchy\"><img src=\"tbl_spacer.png\" alt=\".\" style=\"background-color: inherit\" class=\"hierarchy\"/><img src=\"tbl_vjoin.png\" alt=\".\" style=\"background-color: inherit\" class=\"hierarchy\"/><img src=\"icon-q-coding.png\" alt=\".\" style=\"background-color: white; background-color: inherit\" title=\"coding\" class=\"hierarchy\"/> monitoring-tech</td><td style=\"vertical-align: top; text-align : var(--ig-left,left); background-color: white; border: 1px #F0F0F0 solid; padding:0px 4px 0px 4px\" class=\"hierarchy\">Which remote monitoring capability is available at your facility?</td><td style=\"vertical-align: top; text-align : var(--ig-left,left); background-color: white; border: 1px #F0F0F0 solid; padding:0px 4px 0px 4px\" class=\"hierarchy\">1..1</td><td style=\"vertical-align: top; text-align : var(--ig-left,left); background-color: white; border: 1px #F0F0F0 solid; padding:0px 4px 0px 4px\" class=\"hierarchy\"><a href=\"https://hl7.org/fhir/R4/codesystem-item-type.html#item-type-choice\">choice</a></td><td style=\"vertical-align: top; text-align : var(--ig-left,left); background-color: white; border: 1px #F0F0F0 solid; padding:0px 4px 0px 4px\" class=\"hierarchy\">Opções: <a href=\"#opt-item.monitoring-tech\">3 options</a></td></tr>#xD;\n<tr style=\"border: 1px #F0F0F0 solid; padding:0px; vertical-align: top; background-color: #F7F7F7\"><td style=\"vertical-align: top; text-align : var(--ig-left,left); background-color: #F7F7F7; border: 1px #F0F0F0 solid; padding:0px 4px 0px 4px; white-space: nowrap; background-image: url(tbl_bck00.png)\" id=\"item.financial-navigation\" class=\"hierarchy\"><img src=\"tbl_spacer.png\" alt=\".\" style=\"background-color: inherit\" class=\"hierarchy\"/><img src=\"tbl_vjoin_end.png\" alt=\".\" style=\"background-color: inherit\" class=\"hierarchy\"/><img src=\"icon-q-coding.png\" alt=\".\" style=\"background-color: #F7F7F7; background-color: inherit\" title=\"coding\" class=\"hierarchy\"/> financial-navigation</td><td style=\"vertical-align: top; text-align : var(--ig-left,left); background-color: #F7F7F7; border: 1px #F0F0F0 solid; padding:0px 4px 0px 4px\" class=\"hierarchy\">What financial navigation capacity does your facility have for medication access?</td><td style=\"vertical-align: top; text-align : var(--ig-left,left); background-color: #F7F7F7; border: 1px #F0F0F0 solid; padding:0px 4px 0px 4px\" class=\"hierarchy\">1..1</td><td style=\"vertical-align: top; text-align : var(--ig-left,left); background-color: #F7F7F7; border: 1px #F0F0F0 solid; padding:0px 4px 0px 4px\" class=\"hierarchy\"><a href=\"https://hl7.org/fhir/R4/codesystem-item-type.html#item-type-choice\">choice</a></td><td style=\"vertical-align: top; text-align : var(--ig-left,left); background-color: #F7F7F7; border: 1px #F0F0F0 solid; padding:0px 4px 0px 4px\" class=\"hierarchy\">Opções: <a href=\"#opt-item.financial-navigation\">2 options</a></td></tr>#xD;\n<tr><td colspan=\"5\" class=\"hierarchy\"><br/><a href=\"https://hl7.org/fhir/R4/formats.html#table\" title=\"Legenda para este formato\"><img src=\"data:image/png;base64,\" alt=\"doco\" style=\"background-color: inherit\"/> Documentação para este formato</a></td></tr></table><hr/><p><b>Conjuntos de opções</b></p><a name=\"opt-item.staffing-level\"> </a><p><b>Opções de resposta para staffing-level </b></p><ul><li style=\"font-size: 11px\">RN/MA + MD only (minimal)</li><li style=\"font-size: 11px\">RN champion + PharmD (standard)</li><li style=\"font-size: 11px\">Full multidisciplinary team (RN, PharmD, social worker, CHW) (advanced)</li></ul><a name=\"opt-item.chw-program\"> </a><p><b>Opções de resposta para chw-program </b></p><ul><li style=\"font-size: 11px\">None (rely on family or alternative)</li><li style=\"font-size: 11px\">High-risk patients only</li><li style=\"font-size: 11px\">Full integration across all HF patients</li></ul><a name=\"opt-item.monitoring-tech\"> </a><p><b>Opções de resposta para monitoring-tech </b></p><ul><li style=\"font-size: 11px\">Analog only (telephone, paper diary)</li><li style=\"font-size: 11px\">Dual-track (analog and digital available based on patient)</li><li style=\"font-size: 11px\">Digital primary plus remote patient monitoring (RPM)</li></ul><a name=\"opt-item.financial-navigation\"> </a><p><b>Opções de resposta para financial-navigation </b></p><ul><li style=\"font-size: 11px\">Generic Bridge pathway only (low-cost generics)</li><li style=\"font-size: 11px\">Patient assistance program (PAP) pursuit plus Generic Bridge</li></ul></div>"^^rdf:XMLLiteral ]
  ] ; # 
  fhir:url [
     fhir:v "https://heartlandprotocol.org/fhir/Questionnaire/heartland-facility-tier-questionnaire"^^xsd:anyURI ;
     fhir:l <https://heartlandprotocol.org/fhir/Questionnaire/heartland-facility-tier-questionnaire>
  ] ; # 
  fhir:version [ fhir:v "0.1.0"] ; # 
  fhir:name [ fhir:v "HeartlandFacilityTierQuestionnaire"] ; # 
  fhir:title [ fhir:v "HEARTLAND Facility Tier Questionnaire"] ; # 
  fhir:status [ fhir:v "active"] ; # 
  fhir:experimental [ fhir:v false] ; # 
  fhir:subjectType ( [ fhir:v "Location"] [ fhir:v "Organization"] ) ; # 
  fhir:date [ fhir:v "2026-04-16"^^xsd:date] ; # 
  fhir:publisher [ fhir:v "Vicky Muller Ferreira, MD"] ; # 
  fhir:contact ( [
     fhir:name [ fhir:v "Vicky Muller Ferreira, MD" ] ;
     fhir:telecom ( [
       fhir:system [ fhir:v "url" ] ;
       fhir:value [ fhir:v "https://heartlandprotocol.org" ]
     ] [
       fhir:system [ fhir:v "email" ] ;
       fhir:value [ fhir:v "vickymuller@heartlandprotocol.org" ]
     ] )
  ] [
     fhir:name [ fhir:v "Vicky Muller Ferreira, MD" ] ;
     fhir:telecom ( [
       fhir:system [ fhir:v "email" ] ;
       fhir:value [ fhir:v "vickymuller@heartlandprotocol.org" ] ;
       fhir:use [ fhir:v "work" ]
     ] [
       fhir:system [ fhir:v "url" ] ;
       fhir:value [ fhir:v "https://heartlandprotocol.org" ]
     ] )
  ] ) ; # 
  fhir:description [ fhir:v "Facility self-assessment for HEARTLAND implementation tier (1/2/3). Qualitative scoring; see narrative for tier mapping."] ; # 
  fhir:jurisdiction ( [
     fhir:coding ( [
       fhir:system [
         fhir:v "urn:iso:std:iso:3166"^^xsd:anyURI ;
         fhir:l <urn:iso:std:iso:3166>
       ] ;
       fhir:code [ fhir:v "US" ]
     ] )
  ] ) ; # 
  fhir:purpose [ fhir:v "Help heart failure programs identify the HEARTLAND implementation tier their site can sustainably operate at, given current staffing, technology, and resources."] ; # 
  fhir:item ( [
     fhir:linkId [ fhir:v "staffing-level" ] ;
     fhir:text [ fhir:v "Which staffing model is available for heart failure care at your facility?" ] ;
     fhir:type [ fhir:v "choice" ] ;
     fhir:required [ fhir:v true ] ;
     fhir:answerOption ( [
       fhir:value [
         a fhir:String ;
         fhir:v "RN/MA + MD only (minimal)"
       ]
     ] [
       fhir:value [
         a fhir:String ;
         fhir:v "RN champion + PharmD (standard)"
       ]
     ] [
       fhir:value [
         a fhir:String ;
         fhir:v "Full multidisciplinary team (RN, PharmD, social worker, CHW) (advanced)"
       ]
     ] )
  ] [
     fhir:linkId [ fhir:v "pharmd-available" ] ;
     fhir:text [ fhir:v "Is a PharmD available on-site or by consult to support GDMT titration?" ] ;
     fhir:type [ fhir:v "boolean" ] ;
     fhir:required [ fhir:v true ]
  ] [
     fhir:linkId [ fhir:v "chw-program" ] ;
     fhir:text [ fhir:v "What level of community health worker (CHW) program does your facility have?" ] ;
     fhir:type [ fhir:v "choice" ] ;
     fhir:required [ fhir:v true ] ;
     fhir:answerOption ( [
       fhir:value [
         a fhir:String ;
         fhir:v "None (rely on family or alternative)"
       ]
     ] [
       fhir:value [
         a fhir:String ;
         fhir:v "High-risk patients only"
       ]
     ] [
       fhir:value [
         a fhir:String ;
         fhir:v "Full integration across all HF patients"
       ]
     ] )
  ] [
     fhir:linkId [ fhir:v "monitoring-tech" ] ;
     fhir:text [ fhir:v "Which remote monitoring capability is available at your facility?" ] ;
     fhir:type [ fhir:v "choice" ] ;
     fhir:required [ fhir:v true ] ;
     fhir:answerOption ( [
       fhir:value [
         a fhir:String ;
         fhir:v "Analog only (telephone, paper diary)"
       ]
     ] [
       fhir:value [
         a fhir:String ;
         fhir:v "Dual-track (analog and digital available based on patient)"
       ]
     ] [
       fhir:value [
         a fhir:String ;
         fhir:v "Digital primary plus remote patient monitoring (RPM)"
       ]
     ] )
  ] [
     fhir:linkId [ fhir:v "financial-navigation" ] ;
     fhir:text [ fhir:v "What financial navigation capacity does your facility have for medication access?" ] ;
     fhir:type [ fhir:v "choice" ] ;
     fhir:required [ fhir:v true ] ;
     fhir:answerOption ( [
       fhir:value [
         a fhir:String ;
         fhir:v "Generic Bridge pathway only (low-cost generics)"
       ]
     ] [
       fhir:value [
         a fhir:String ;
         fhir:v "Patient assistance program (PAP) pursuit plus Generic Bridge"
       ]
     ] )
  ] ) . # 

